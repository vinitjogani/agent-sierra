CURSOR_API_KEY=your_cursor_api_key
CURSOR_MODEL=cursor-composer-1-5
GITHUB_REPOSITORY=https://github.com/your-org/your-repo
GITHUB_REF=main
CURSOR_AUTO_CREATE_PR=true
REDIS_URL=redis://localhost:6379/0
SENTRY_WEBHOOK_SECRET=your_sentry_client_secret
SENTRY_AUTH_TOKEN=your_sentry_auth_token
DASHBOARD_PASSWORD=your_dashboard_password
# Optional: map Sentry project slugs to repos (SENTRY_PROJECT_<slug>=url)
# SENTRY_PROJECT_python=https://github.com/org/python-backend
# SENTRY_PROJECT_frontend=https://github.com/org/frontend
